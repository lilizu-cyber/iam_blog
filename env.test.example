# Test Environment Variables
NODE_ENV=test

# Test Database (separate from development)
POSTGRESQL_URI=postgresql://postgres:postgres@localhost:5432/iam_blog_test
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/iam_blog_test

# Test Redis (use different database)
REDIS_URL=redis://localhost:6379/1

# Test JWT Secret (can be shorter for tests, but still secure)
JWT_SECRET=test-jwt-secret-key-for-testing-only-minimum-32-characters-long

# Disable external services in tests
OPENAI_API_KEY=
ERROR_NOTIFICATIONS_ENABLED=false

# Test-specific settings
MEMORY_WARNING_THRESHOLD=95

