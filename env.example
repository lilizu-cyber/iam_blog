# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
# PostgreSQL (for Read Models and Event Store)
POSTGRESQL_URI=postgresql://postgres:postgres@localhost:5432/iam_blog_db
# Or use DATABASE_URL (alternative name)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/iam_blog_db

EVENTSTORE_CONNECTION_STRING=esdb://localhost:2113?tls=false

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Security
BCRYPT_ROUNDS=12

# Admin User Configuration (for initial setup)
# These are used only when creating the first admin user via script
# After creation, change password through admin panel or database
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Schlurfend.?.123
ADMIN_EMAIL=admin@example.com

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
IMAGE_OPTIMIZATION_ENABLED=true

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Auth0 (backend validates tokens via /userinfo)
AUTH0_DOMAIN=dev-iybt2laalx0jrsf4.eu.auth0.com

# Auth0 (frontend - set on Vercel for production builds)
# VITE_AUTH0_DOMAIN=dev-iybt2laalx0jrsf4.eu.auth0.com
# VITE_AUTH0_CLIENT_ID=your-auth0-spa-client-id
# VITE_API_URL=https://your-backend.example.com/api

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Request Timeout (milliseconds)
# Default: 25000 (25 seconds - 5 seconds before Heroku's 30s limit)
# REQUEST_TIMEOUT_MS=25000

# Database Backup Configuration
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESS=true
BACKUP_FORMAT=custom

# Database Connection Pool Configuration (optional - defaults shown)
# DB_POOL_MAX=10
# DB_POOL_MIN=2
# DB_POOL_ACQUIRE=30000
# DB_POOL_IDLE=10000

# Logging Configuration
# LOG_RETENTION_DAYS=30
# LOG_MAX_SIZE=20m
# LOG_DATE_PATTERN=YYYY-MM-DD

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# APM Configuration (optional)
# New Relic
# NEW_RELIC_LICENSE_KEY=your-new-relic-license-key
# NEW_RELIC_APP_NAME=iam-blog-backend

# Datadog
# DD_API_KEY=your-datadog-api-key
# DD_SERVICE=iam-blog-backend
# DD_ENV=production

# Sentry
# SENTRY_DSN=your-sentry-dsn
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# Rollbar (alternative to Sentry)
# ROLLBAR_ACCESS_TOKEN=your-rollbar-access-token

# Error Notifications
# ERROR_NOTIFICATIONS_ENABLED=true
# ERROR_NOTIFICATION_EMAIL=admin@example.com
# ERROR_NOTIFICATION_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# ERROR_NOTIFICATION_THRESHOLD=5
