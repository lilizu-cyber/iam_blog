{
  "name": "iam-cybersecurity-blog",
  "version": "1.0.0",
  "description": "Cybersecurity and IAM Blog with CQRS and Event-Driven Architecture",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node scripts/check-dependencies.js && nodemon --exec \"node --max-old-space-size=4096\" src/backend/server.js",
    "dev:frontend": "cd frontend && npm start",
    "check:deps": "node scripts/check-dependencies.js",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "babel src/backend -d dist/backend",
    "build:frontend": "cd frontend && npm run build",
    "start": "node --max-old-space-size=4096 dist/backend/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:sanitization": "jest tests/unit/utils/sanitizer.test.js tests/unit/middleware/sanitizeMiddleware.test.js tests/unit/utils/sqlInjectionCheck.test.js",
    "test:sanitization:manual": "node scripts/test-sanitization.js",
    "test:token-refresh": "node scripts/test-token-refresh.js",
    "test:security-headers": "node scripts/test-security-headers.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "setup:db": "node scripts/setup-postgresql.js",
    "create:admin": "node scripts/create-admin-user.js",
    "test:auth": "node scripts/test-auth.js",
    "generate:jwt": "node scripts/generate-jwt-secret.js",
    "migrate:up": "node scripts/run-migrations.js up",
    "migrate:status": "node scripts/run-migrations.js status",
    "backup:db": "node scripts/backup-database.js",
    "backup:db:docker": "node scripts/backup-database-docker.js",
    "restore:db": "node scripts/restore-database.js",
    "restore:list": "node scripts/restore-database.js --list",
    "indexes:verify": "node scripts/verify-indexes.js",
    "indexes:create": "node scripts/create-missing-indexes.js",
    "indexes:analyze": "node scripts/analyze-query-performance.js"
  },
  "dependencies": {
    "@eventstore/db-client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "isomorphic-dompurify": "^2.33.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.104.0",
    "pg": "^8.11.3",
    "rate-limit-redis": "^4.3.1",
    "redis": "^4.6.10",
    "sequelize": "^6.35.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.4",
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@playwright/test": "^1.40.0",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "jsdom": "^27.2.0",
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.6.2",
    "supertest": "^6.3.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "keywords": [
    "cybersecurity",
    "iam",
    "blog",
    "cqrs",
    "event-driven",
    "security"
  ],
  "author": "Your Name",
  "license": "MIT"
}
